{
  "rewrites": [
    {
      "source": "/support",
      "destination": "https://hufi-docs.vercel.app/"
    },
    {
      "source": "/support/(.*)",
      "destination": "https://hufi-docs.vercel.app/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "buildCommand": "yarn build",
  "outputDirectory": "dist",
  "framework": "vite"
}
